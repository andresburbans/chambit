rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Default Deny ─────────────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // ─── Avatars ──────────────────────────────────────────────────────────────
    // Path: /avatars/{uid}.webp
    // Public read (displayed on listing cards without auth).
    // Write: owner only, WebP only, max 60 KB (enforces client-side resize to 200×200).
    match /avatars/{userId}.webp {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size <= 60 * 1024
                   && request.resource.contentType == 'image/webp';
    }

    // ─── Service Portfolio ────────────────────────────────────────────────────
    // Path: /services/{uid}/{listingId}.webp
    // Public read (shown in listing cards).
    // Write: owner only, WebP only, max 350 KB (1200px long edge).
    match /services/{userId}/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size <= 350 * 1024
                   && request.resource.contentType == 'image/webp';
    }

    // ─── Request Evidence ─────────────────────────────────────────────────────
    // Path: /requests/{requestId}/{imageId}
    // Read: any authenticated user who has the exact path (security through obscurity +
    //   auth). True party-based restriction requires a Firestore lookup not available
    //   in Storage rules — enforced at application layer.
    // Write: any authenticated user (client creates on request creation).
    //   Size + WebP enforcement protects against abuse.
    match /requests/{requestId}/{imageId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size <= 350 * 1024
                   && request.resource.contentType == 'image/webp';
    }

    // ─── Temporary Uploads ────────────────────────────────────────────────────
    // Path: /temp/{uid}/{anything}
    // Used during client-side processing pipeline before writing to final path.
    // Auto-deleted by Cloud Function or Storage lifecycle rule (24h).
    match /temp/{userId}/{allPaths=**} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size <= 10 * 1024 * 1024; // 10 MB raw max
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
