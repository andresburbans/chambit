{
    "name": "chambit-functions",
    "version": "0.2.0",
    "private": true,
    "main": "lib/index.js",
    "scripts": {
        "build": "tsc",
        "build:watch": "tsc --watch",
        "serve": "npm run build && firebase emulators:start --only functions",
        "shell": "npm run build && firebase functions:shell",
        "start": "npm run shell",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log",
        "lint": "tsc --noEmit",
        "seed": "npx ts-node -P ../tsconfig.seed.json src/scripts/seedData.ts",
        "seed:v2": "npx ts-node -P ../tsconfig.seed.json src/scripts/seedDataV2.ts",
        "seed:v2b": "npx ts-node -P ../tsconfig.seed.json src/scripts/seedDataV2b.ts",
        "seed:backfill": "npx ts-node -P ../tsconfig.seed.json src/scripts/backfillH3Index.ts"
    },
    "engines": {
        "node": "22"
    },
    "dependencies": {
        "firebase-admin": "^13.4.0",
        "firebase-functions": "^6.3.2",
        "h3-js": "^4.2.1"
    },
    "devDependencies": {
        "typescript": "^5.7.3",
        "firebase-functions-test": "^3.4.0"
    }
}