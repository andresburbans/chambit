rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    // Protects against mass field injection
    function validUserWrite() {
      let allowed = [
        'uid','email','createdAt','displayName','firstName','lastName','phone',
        'cc','birthYear','avatarUrl','role','preferredCategories','expertPopupDismissals',
        'fcmToken','h3Res9','country','geozoneId','isExpertEnabled',
        'lastActiveAt','expert'
      ];
      return request.resource.data.keys().hasOnly(allowed);
    }

    // ─── Default Deny ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── D01: Users ───────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isOwner(userId);
      allow create: if isOwner(userId) && validUserWrite();
      allow update: if isOwner(userId) && validUserWrite();
      allow delete: if false;
    }

    // ─── D02: Service Listings ────────────────────────────────────────────────
    match /serviceListings/{listingId} {
      allow read, list: if true;
      allow write:      if false;
    }

    // ─── D03: Requests ────────────────────────────────────────────────────────
    // `list` is needed for collection queries (onSnapshot with where clause).
    // We allow any authenticated user to list requests — the client then only
    // sees their own because the query filters by clientId/acceptedExpertId.
    match /requests/{requestId} {
      allow list:   if isAuth();
      allow get:    if isAuth() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.acceptedExpertId == request.auth.uid
      );
      allow create: if isAuth() && request.resource.data.clientId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.acceptedExpertId == request.auth.uid
      );
      allow delete: if false;

      // Messages subcollection
      match /messages/{msgId} {
        allow list, get: if isAuth() && (
          get(/databases/$(database)/documents/requests/$(requestId)).data.clientId == request.auth.uid ||
          get(/databases/$(database)/documents/requests/$(requestId)).data.acceptedExpertId == request.auth.uid
        );
        allow create: if isAuth() && (
          get(/databases/$(database)/documents/requests/$(requestId)).data.clientId == request.auth.uid ||
          get(/databases/$(database)/documents/requests/$(requestId)).data.acceptedExpertId == request.auth.uid
        ) && request.resource.data.keys().hasAll(['senderId','text','type','createdAt'])
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }

      // Offers subcollection
      match /offers/{offerId} {
        allow list, get: if isAuth() && (
          get(/databases/$(database)/documents/requests/$(requestId)).data.clientId == request.auth.uid ||
          request.auth.uid == resource.data.expertId
        );
        allow create: if isAuth();
        allow update, delete: if false;
      }
    }

    // ─── D04: Ratings ─────────────────────────────────────────────────────────
    match /ratings/{ratingId} {
      allow read, list: if true;
      allow write:      if false;
    }

    // ─── D05: Categories & Subcategories ──────────────────────────────────────
    match /categories/{categoryId} {
      allow read, list: if true;
      allow write:      if false;

      match /subcategories/{subId} {
        allow read, list: if true;
        allow write:      if false;
      }
    }

    // ─── D06: App Config ──────────────────────────────────────────────────────
    match /config/{docId} {
      allow read, list: if isAuth();
      allow write:      if false;
    }

    // ─── D07: Geozones ────────────────────────────────────────────────────────
    match /geozones/{zoneId} {
      allow read, list: if true;
      allow write:      if false;
    }

    // ─── D08: Notifications ───────────────────────────────────────────────────
    // `list` is needed for collection queries (onSnapshot + getCountFromServer).
    match /notifications/{notifId} {
      allow list: if isAuth();
      allow get:  if isAuth() && resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }
  }
}
