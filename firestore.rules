rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Users: owner can read/write their own document
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Service Listings: public read, write through Cloud Functions only
    match /serviceListings/{listingId} {
      allow read: if true;
      allow write: if false; // Only via Cloud Functions (admin SDK)
    }

    // Requests: parties can read, write through Cloud Functions
    match /requests/{requestId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.clientId ||
         request.auth.uid == resource.data.expertId);
      allow write: if false; // Only via Cloud Functions
    }

    // Ratings: public read, write through Cloud Functions
    match /ratings/{ratingId} {
      allow read: if true;
      allow write: if false; // Only via Cloud Functions
    }

    // Categories: public read, admin write
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false; // Seeded via admin SDK
      
      match /subcategories/{subId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Config: public read, admin write
    match /config/{docId} {
      allow read: if true;
      allow write: if false; // Only via admin SDK
    }

    // Notifications: owner can read, Cloud Functions write
    match /notifications/{notifId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create, delete: if false; // Only via Cloud Functions
    }
  }
}
